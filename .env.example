# NVIDIA NIM API configuration
NVIDIA_API_KEY=your_nvidia_api_key_here

# Supabase database config (Frontend)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_anon_key_here

# Supabase database config (Backend - Optional)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=https://your-supabase-project.supabase.co/auth/v1/.well-known/jwks.json
